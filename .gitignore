# Symlinks locais — não versionar
/CLAUDE.md

# Git worktrees locais — isolamento de trabalho
.worktrees/

# Infraestrutura de desenvolvimento — não distribuir ao cliente
.dev/

# Memória de operação local
memory.op.md

# Outputs de teste
.dev/test-outputs/

# Outputs de execução de processos (artefatos runtime)
*/outputs/*
!*/outputs/.gitkeep

# Mission Control — artefatos de runtime local
.mission-control/db/
.mission-control/pid
.mission-control/port

# Dependências
node_modules/

# OS
.DS_Store
Thumbs.db

# Config de fontes de dados por processo (credenciais locais)
**/config.json

# Skills compartilhadas — node_modules locais por ferramenta
.skills/_lib/*/node_modules/
.skills/_lib/*/test/output/
